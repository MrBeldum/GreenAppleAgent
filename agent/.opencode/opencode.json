{
  "$schema": "https://opencode.ai/config.json",
  "model": "",
  "small_model": "",
  "default_agent": "operator",
  "instructions": [
    ".opencode/instructions/INSTRUCTIONS.md",
    "skills/web-recon/SKILL.md",
    "skills/port-scanning/SKILL.md",
    "skills/directory-fuzzing/SKILL.md",
    "skills/parameter-fuzzing/SKILL.md",
    "skills/sqli-testing/SKILL.md",
    "skills/xss-testing/SKILL.md",
    "skills/auth-bypass/SKILL.md",
    "skills/ssrf-testing/SKILL.md",
    "skills/file-inclusion/SKILL.md",
    "skills/report-generation/SKILL.md",
    "skills/source-analysis/SKILL.md",
    "skills/command-injection/SKILL.md",
    "skills/ssti-testing/SKILL.md",
    "skills/idor-testing/SKILL.md",
    "skills/csrf-testing/SKILL.md",
    "skills/xxe-testing/SKILL.md",
    "skills/deserialization-testing/SKILL.md",
    "skills/jwt-testing/SKILL.md",
    "skills/websocket-testing/SKILL.md",
    "skills/graphql-testing/SKILL.md",
    "skills/file-upload-testing/SKILL.md",
    "skills/cors-testing/SKILL.md",
    "skills/request-smuggling/SKILL.md",
    "skills/race-condition-testing/SKILL.md",
    "skills/info-disclosure-testing/SKILL.md",
    "skills/business-logic-testing/SKILL.md",
    "skills/subdomain-enumeration/SKILL.md",
    "skills/user-enumeration/SKILL.md",
    "skills/open-redirect-testing/SKILL.md",
    "skills/osint-recon/SKILL.md",
    "skills/sensitive-data-detection/SKILL.md",
    "references/hackthebox-machine-mode.md",
    "references/INDEX.md"
  ],
  "plugin": [
    "./plugins"
  ],
  "agent": {
    "operator": {
      "description": "Lead HackTheBox operator. Drives enumeration, exploit planning, user/root flag pursuit, reporting, and subagent coordination for authorized machines.",
      "mode": "primary",
      "prompt": "{file:prompts/agents/operator.txt}",
      "read": true,
      "write": true,
      "edit": true,
      "bash": true,
      "glob": true,
      "grep": true
    },
    "recon-specialist": {
      "description": "HackTheBox recon specialist: fingerprinting, service enumeration, directory fuzzing, and attack-surface discovery for the assigned machine.",
      "mode": "subagent",
      "prompt": "{file:prompts/agents/recon-specialist.txt}",
      "read": true,
      "write": false,
      "edit": false,
      "bash": true,
      "glob": true,
      "grep": false
    },
    "vulnerability-analyst": {
      "description": "HackTheBox vulnerability analyst: triages discovered surface, prioritizes foothold and privilege-escalation paths, and returns evidence-backed recommendations.",
      "mode": "subagent",
      "prompt": "{file:prompts/agents/vulnerability-analyst.txt}",
      "read": true,
      "write": false,
      "edit": false,
      "bash": true,
      "glob": true,
      "grep": true
    },
    "exploit-developer": {
      "description": "HackTheBox exploit specialist: crafts and executes in-scope exploits, chains impact, and pursues user/root flag proof when assigned.",
      "mode": "subagent",
      "prompt": "{file:prompts/agents/exploit-developer.txt}",
      "read": true,
      "write": false,
      "edit": false,
      "bash": true,
      "glob": true,
      "grep": true
    },
    "fuzzer": {
      "description": "HackTheBox fuzzer: bounded high-volume fuzzing for paths, parameters, and credentials that may unlock foothold or privilege escalation.",
      "mode": "subagent",
      "prompt": "{file:prompts/agents/fuzzer.txt}",
      "read": true,
      "write": false,
      "edit": false,
      "bash": true,
      "glob": true,
      "grep": true
    },
    "source-analyzer": {
      "description": "HackTheBox source analyzer: extracts hidden routes, APIs, secrets, and client-side attack surface from fetched HTML/JS/CSS.",
      "mode": "subagent",
      "prompt": "{file:prompts/agents/source-analyzer.txt}",
      "read": true,
      "write": false,
      "edit": false,
      "bash": true,
      "glob": true,
      "grep": true
    },
    "report-writer": {
      "description": "HackTheBox report writer: generates a detailed beginner-friendly Markdown walkthrough from logs, findings, proof, and flags.",
      "mode": "subagent",
      "prompt": "{file:prompts/agents/report-writer.txt}",
      "read": true,
      "write": true,
      "edit": true,
      "bash": true,
      "glob": true,
      "grep": true
    },
    "osint-analyst": {
      "description": "HackTheBox OSINT analyst: enriches intel.md with CVE, breach, DNS, and contextual clues that support authorized machine exploitation.",
      "mode": "subagent",
      "prompt": "{file:prompts/agents/osint-analyst.txt}",
      "read": true,
      "write": false,
      "edit": false,
      "bash": true,
      "glob": true,
      "grep": true
    }
  },
  "command": {
    "engage": {
      "description": "Start engagement (add --auto for fully autonomous mode)",
      "template": "{file:commands/engage.md}\n\n$ARGUMENTS",
      "agent": "operator",
      "subtask": false
    },
    "autoengage": {
      "description": "Shortcut for /engage --auto",
      "template": "{file:commands/engage.md}\n\n--auto $ARGUMENTS",
      "agent": "operator",
      "subtask": false
    },
    "recon": {
      "description": "Manual override: run reconnaissance phase",
      "template": "{file:commands/recon.md}\n\n$ARGUMENTS",
      "agent": "recon-specialist",
      "subtask": true
    },
    "scan": {
      "description": "Manual override: run active scanning phase",
      "template": "{file:commands/scan.md}\n\n$ARGUMENTS",
      "agent": "recon-specialist",
      "subtask": true
    },
    "enumerate": {
      "description": "Manual override: run enumeration phase",
      "template": "{file:commands/enumerate.md}\n\n$ARGUMENTS",
      "agent": "recon-specialist",
      "subtask": true
    },
    "vuln-analyze": {
      "description": "Manual override: run vulnerability analysis",
      "template": "{file:commands/vuln-analyze.md}\n\n$ARGUMENTS",
      "agent": "vulnerability-analyst",
      "subtask": true
    },
    "exploit": {
      "description": "Manual override: exploit a specific finding",
      "template": "{file:commands/exploit.md}\n\n$ARGUMENTS",
      "agent": "exploit-developer",
      "subtask": true
    },
    "pivot": {
      "description": "Force strategy change based on current findings",
      "template": "{file:commands/pivot.md}\n\n$ARGUMENTS",
      "agent": "operator",
      "subtask": false
    },
    "status": {
      "description": "Show engagement progress and findings summary",
      "template": "{file:commands/status.md}\n\n$ARGUMENTS",
      "agent": "operator",
      "subtask": false
    },
    "report": {
      "description": "Generate final engagement report",
      "template": "{file:commands/report.md}\n\n$ARGUMENTS",
      "agent": "report-writer",
      "subtask": true
    },
    "proxy": {
      "description": "Start or stop the mitmproxy interception proxy",
      "template": "{file:commands/proxy.md}\n\n$ARGUMENTS",
      "agent": "operator",
      "subtask": false
    },
    "auth": {
      "description": "Configure authentication credentials (cookies, headers)",
      "template": "{file:commands/auth.md}\n\n$ARGUMENTS",
      "agent": "operator",
      "subtask": false
    },
    "queue": {
      "description": "Show case queue statistics",
      "template": "{file:commands/queue.md}\n\n$ARGUMENTS",
      "agent": "operator",
      "subtask": false
    },
    "stop": {
      "description": "Stop all background engagement processes",
      "template": "{file:commands/stop.md}\n\n$ARGUMENTS",
      "agent": "operator",
      "subtask": false
    },
    "confirm": {
      "description": "Toggle auto/manual confirmation mode (default: auto)",
      "template": "{file:commands/confirm.md}\n\n$ARGUMENTS",
      "agent": "operator",
      "subtask": false
    },
    "resume": {
      "description": "Resume an interrupted engagement from where it left off",
      "template": "{file:commands/resume.md}\n\n$ARGUMENTS",
      "agent": "operator",
      "subtask": false
    },
    "config": {
      "description": "View or change runtime config (parallel, batch_size)",
      "template": "{file:commands/config.md}\n\n$ARGUMENTS",
      "agent": "operator",
      "subtask": false
    },
    "subdomain": {
      "description": "Enumerate subdomains for a target domain",
      "template": "TARGET_DOMAIN: $ARGUMENTS\n\n{file:commands/subdomain.md}",
      "agent": "recon-specialist",
      "subtask": true
    },
    "htb": {
      "description": "Start a HackTheBox machine engagement from a Parrot/Kali VM",
      "template": "{file:commands/htb.md}\n\n{file:commands/engage.md}\n\n$ARGUMENTS",
      "agent": "operator",
      "subtask": false
    },
    "osint": {
      "description": "Run OSINT intelligence gathering on current engagement",
      "template": "{file:commands/osint.md}\n\n$ARGUMENTS",
      "agent": "osint-analyst",
      "subtask": true
    }
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "bash": "allow",
    "glob": "allow",
    "grep": "allow",
    "skill": {
      "using-superpowers": "deny"
    }
  }
}
